# ─────────────────────────────────────────────────────────────
# Personal info. Copy this file to `.env` and fill in your values.
# Everything is optional — leave a field EMPTY to hide it gracefully.
# After editing .env, restart `npm run dev` (Vite reads env at startup).
# ─────────────────────────────────────────────────────────────

# Identity
VITE_NAME="Your Name"
VITE_LOGO="yourname"                       # header logo text / monogram
VITE_ROLE="Software Developer"
VITE_BIO="One or two sentences about you, shown by the 'about' command."
VITE_LOCATION="City, Country"

# Contact / socials — leave any EMPTY to hide that footer icon.
VITE_EMAIL="you@example.com"
VITE_GITHUB="https://github.com/yourname"
VITE_LINKEDIN="https://linkedin.com/in/yourname"
VITE_INSTAGRAM="https://instagram.com/yourname"
